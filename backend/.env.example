# ─────────────────────────────────────────────
# Seedance Wizard Backend 环境变量
# 复制此文件为 .env 并填入真实值
# ─────────────────────────────────────────────

# 服务端口
PORT=3000

# PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seedance

# DeepSeek API Key（导演对话，兼容 OpenAI SDK 格式）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 阿里云 DashScope API Key（Qwen VL 图像分析）
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# muapi.ai API Key（Flux 预览 + Seedance 出片）
# 获取地址: https://muapi.ai
MUAPI_KEY=your-muapi-api-key

# JWT 签名密钥（用于用户登录 token 签发）
# 生产环境请使用随机字符串，至少 32 字符
JWT_SECRET=change-me-to-a-random-secret-string-at-least-32-chars

# 短信服务商 API Key（注册验证码，国内版可先 mock）
# 留空时验证码会打印到控制台
SMS_PROVIDER_KEY=

# ═══════════════════════════════════════════════
# 部署区域：cn=国内版（默认）| intl=海外版
# ═══════════════════════════════════════════════
DEPLOYMENT_REGION=cn

# Google OAuth Client ID（海外版，国内版留空）
# 获取地址: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Stripe 密钥（海外版，支付暂未上线，可留空）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2（海外版 CDN，国内版留空）
R2_BUCKET=
