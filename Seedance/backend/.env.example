# ============================================================
# Seedance Studio 环境变量模板
# 复制此文件为 .env 并填入真实值
# Railway 部署：在 Dashboard → Variables 中逐个添加
# ECS 部署：docker compose 自动读取 .env
# ============================================================

# 部署区域：intl=海外版(英文/USD/Stripe) | cn=国内版(中文/RMB/微信支付)
DEPLOYMENT_REGION=intl

# EvoLink API Key（图片生成 + Kling/Wan/Hailuo 视频草稿 + 音乐）
# 注册：https://evolink.ai
# 注意：Seedance 2.0 已切换为火山引擎直连，不再经过 EvoLink
EVOLINK_API_KEY=sk-your-evolink-key

# 火山引擎 ARK API Key（Seedance 2.0 视频草稿 + 最终成片 + 视觉分析）
# 注册：https://console.volcengine.com → 方舟平台
# 需要开通以下模型权限：
#   - doubao-seedance-2-0-fast-260128（720p 极速版）
#   - doubao-seedance-2-0-260128（1080p 标准版）
#   - doubao-1-5-vision-pro-32k-250115（视觉描述）
VOLC_API_KEY=ark-your-volc-key

# JWT 签名密钥（生产必须设置随机值：openssl rand -hex 32）
JWT_SECRET=your-random-secret

# Admin API Key（用于 /admin/init-db 等管理端点）
# ADMIN_KEY=your-admin-key

# 服务基础 URL（用于 Stripe 回调、分享链接等）
BASE_URL=http://localhost:8000

# ─── 数据库（PostgreSQL）────────────────────────────────────
# Railway：DATABASE_URL 自动注入，无需手动设置
# docker compose：自动拼接为 postgresql://seedance:${DB_PASSWORD}@db:5432/seedance
DB_PASSWORD=seedance-dev
# 手动部署时取消注释下行：
# DATABASE_URL=postgresql://seedance:seedance-dev@localhost:5432/seedance

# ─── 对象存储 ──────────────────────────────────────────────
# Cloudflare R2（海外版）：从 R2 Dashboard → Manage API Tokens 获取
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=seedance-uploads
# R2_PUBLIC_BASE=https://pub.<your-domain>  （bucket 绑定自定义域名后设为公网访问地址）
#
# imgbb（降级，免费 32MB）：https://api.imgbb.com
IMGBB_API_KEY=your-imgbb-key

# ─── 第三方 OAuth 登录（可选）───────────────────────────────
# Google Sign-In：Google Cloud Console → APIs & Services → Credentials
# 只需 Web Client ID，后端通过 Google 公钥验签，无需 Client Secret
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
#
# GitHub OAuth：GitHub Settings → Developer settings → OAuth Apps
# 回调地址设为: https://你的域名/api/auth/github/callback
# GITHUB_CLIENT_ID=Ov23li...
# GITHUB_CLIENT_SECRET=ghs_xxx

# ─── 支付（可选）───────────────────────────────────────────
# Stripe（海外版）：从 Stripe Dashboard → Developers → API Keys 获取
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# 微信支付（国内版）：从微信支付商户平台获取
# WECHAT_APP_ID=wxXXX
# WECHAT_MCH_ID=1234567890
# WECHAT_API_KEY=your-wechat-api-key

# Redis 连接（可选，不填则降级为内存存储）
# REDIS_URL=redis://your-redis:6379/0
